# Example environment variables for local development
# Copy this file to `.env` and replace values as needed.

# SQLite file-based DB (default for local development)
DATABASE_URL="file:./dev.db"

# JWT secret used to sign tokens returned by /api/auth/login
# WARNING: use a strong secret in production and do NOT commit it to source control
JWT_SECRET="change_this_to_a_secure_secret"

# Backend server port
PORT=3000

# Optional: set NODE_ENV=production in production environments
NODE_ENV=development
